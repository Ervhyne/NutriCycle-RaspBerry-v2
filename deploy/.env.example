    # Example .env for deploy/webrtc_server.py
    # Copy to deploy/.env and fill in values (do NOT commit .env)

    # Core inference and camera
    MODEL_PATH=models/best2.onnx
    VIDEO_SOURCE=0
    CONFIDENCE=0.5
    INFERENCE_IMGSZ=320
    FLIP_MODE=vertical
    CAPTURE_WIDTH=320
    CAPTURE_HEIGHT=240
    # Auto-probe a working numeric camera index at boot.
    # Keeps VIDEO_SOURCE as preferred first choice, then tries 0..CAMERA_PROBE_MAX_INDEX.
    AUTO_CAMERA_PROBE=true
    CAMERA_PROBE_MAX_INDEX=4

    # WebRTC server
    WEBRTC_HOST=0.0.0.0
    WEBRTC_PORT=8080

    # Network & announce
    MACHINE_ID=NC-001
    PUBLIC_URL=https://your-public-stream-url.example.com/
    ANNOUNCE_SERVER=
    ANNOUNCE_INTERVAL=60

    # NutriCycle API configuration
    API_BASE_URL=https://nutricycle-server-production.up.railway.app
    MACHINE_SECRET=replace_with_machine_secret
    STATUS_UPDATE_INTERVAL=60
    SERVER_URL=https://nutricycle-server-production.up.railway.app

    # Keepalive mode:
    # - PERSISTENT=true: always run inference with no browser clients
    # - PERSISTENT=false: inference starts/stops from MQTT start/stop/completion commands
    PERSISTENT=false
    KEEPALIVE_FPS=2

    # Line trigger mode (equivalent to:
    # --trigger-line-y 0.55 --line-trigger-enabled --after-line-side top --trigger-stable-frames 3)
    LINE_TRIGGER_ENABLED=true
    TRIGGER_LINE_Y=0.55
    AFTER_LINE_SIDE=top
    TRIGGER_STABLE_FRAMES=3
    TRIGGER_MIN_CONF=
    TRIGGER_CLASS=

    # MQTT
    MQTT_BROKER=192.168.1.43
    MQTT_PORT=1883
    MQTT_TOPIC=nutricycle/detections
    MQTT_ESP_TOPIC=nutricycle/esp32
    MQTT_CONTROL_TOPIC=nutricycle/rpi/control/+
    MQTT_ESP_COMMAND_TOPIC=nutricycle/esp32/{machineId}/command
    MQTT_USERNAME=
    MQTT_PASSWORD=
    MQTT_QOS=1

    # Optional control token for /control endpoint (Bearer token)
    CONTROL_TOKEN=

    # ngrok startup behavior for auto-run service
    # If true, service exits when tunnel URL is not ready so systemd retries.
    NGROK_REQUIRED=true
    # Seconds to wait for ngrok public URL from http://127.0.0.1:4040/api/tunnels
    NGROK_READY_TIMEOUT=20

    # ICE (WebRTC connectivity)
    # STUN list used by both server and browser client.
    ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302,stun:stun.relay.metered.ca:80
    # Configure TURN for reliable remote/mobile connectivity behind NAT.
    ICE_TURN_URL=
    ICE_TURN_USERNAME=
    ICE_TURN_PASSWORD=
    # Set true only when TURN is configured and you want relay-only media.
    ICE_FORCE_RELAY=false

{
  "topic": "nutricycle/esp32/control",
  "notes": [
    "Send these JSON payloads to the MQTT topic above.",
    "batchNumber is optional for sorting_*; the Pi will auto-use the latest cached batch or create one via device start.",
    "completion is an alias of feed_completed.",
    "estimatedWeight can be sent on start (or as telemetry) and will be patched to the latest/resolved batch."
  ],
  "commands": {
    "start": {
      "command": "start",
      "estimatedWeight": 2.5
    },
    "stop": {
      "command": "stop"
    },
    "sorting_compost": {
      "command": "sorting_compost"
    },
    "sorting_animal_feed": {
      "command": "sorting_animal_feed"
    },
    "dehydration": {
      "command": "dehydration"
    },
    "completion": {
      "command": "completion"
    },
    "feed_completed": {
      "command": "feed_completed"
    }
  },
  "telemetry_examples": {
    "latest_batch_estimated_weight": {
      "estimatedWeight": 2.5
    },
    "latest_batch_humidity_temperature": {
      "humidity": 62.5,
      "temperature": 45.2
    },
    "humidity_temperature": {
      "humidity": 62.5,
      "temperature": 45.2
    },
    "outputs": {
      "feedOutput": 1,
      "compostOutput": 0
    }
  }
}

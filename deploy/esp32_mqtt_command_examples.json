{
  "topic": "nutricycle/rpi/control/NC-001",
  "notes": [
    "Send these JSON payloads to the MQTT topic above where the suffix is the machineId.",
    "batchNumber is optional for sorting_*; the Pi will auto-use the latest cached batch or create one via device start.",
    "completion is an alias of feed_completed.",
    "estimatedWeight can be sent as telemetry and will be patched to the latest/resolved batch."
  ],
  "commands": {
    "emergency_stop": {
      "command": "emergency_stop",
      "commandId": "57f5df96-bbf0-4dd2-8d57-a6c622153d5e",
      "machineId": "NC-001",
      "batchNumber": "BATCH-001"
    },
    "stop": {
      "command": "stop"
    },
    "sorting_compost": {
      "command": "sorting_compost"
    },
    "sorting_animal_feed": {
      "command": "sorting_animal_feed"
    },
    "dehydration": {
      "command": "dehydration"
    },
    "completion": {
      "command": "completion"
    },
    "feed_completed": {
      "command": "feed_completed"
    }
  },
  "telemetry_examples": {
    "latest_batch_estimated_weight": {
      "estimatedWeight": 2.5
    },
    "latest_batch_humidity_temperature": {
      "humidity": 62.5,
      "temperature": 45.2
    },
    "humidity_temperature": {
      "humidity": 62.5,
      "temperature": 45.2
    },
    "outputs": {
      "feedOutput": 1,
      "compostOutput": 0
    }
  },
  "esp32_ack_example": {
    "topic": "nutricycle/esp32/NC-001/ack",
    "payload": {
      "commandId": "57f5df96-bbf0-4dd2-8d57-a6c622153d5e",
      "machineId": "NC-001",
      "success": true
    }
  }
}

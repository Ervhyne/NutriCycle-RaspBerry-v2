# Local runtime config for deploy/webrtc_server.py
# This file is ignored by git.

# Core inference and camera
MODEL_PATH=deploy/models/best2.onnx
VIDEO_SOURCE=0
CONFIDENCE=0.5
INFERENCE_IMGSZ=320
FLIP_MODE=vertical
CAPTURE_WIDTH=640
CAPTURE_HEIGHT=480

# WebRTC server
WEBRTC_HOST=0.0.0.0
WEBRTC_PORT=8080

# Network & machine identity
MACHINE_ID=NC-001
PUBLIC_URL=
ANNOUNCE_SERVER=
ANNOUNCE_INTERVAL=60

# NutriCycle API
API_BASE_URL=https://nutricycle-server-production.up.railway.app
MACHINE_SECRET=5jx625dzwvp
STATUS_UPDATE_INTERVAL=60
SERVER_URL=https://nutricycle-server-production.up.railway.app

# Keepalive
PERSISTENT=false
KEEPALIVE_FPS=2

# Line trigger mode
LINE_TRIGGER_ENABLED=true
TRIGGER_LINE_Y=0.55
AFTER_LINE_SIDE=top
TRIGGER_STABLE_FRAMES=3
TRIGGER_MIN_CONF=
TRIGGER_CLASS=

# MQTT
MQTT_BROKER=192.168.1.43
MQTT_PORT=1883
MQTT_TOPIC=nutricycle/detections
MQTT_ESP_TOPIC=nutricycle/esp32
MQTT_CONTROL_TOPIC=nutricycle/esp32/control
MQTT_USERNAME=
MQTT_PASSWORD=
